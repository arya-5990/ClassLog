rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection - allow read/write for authenticated users
    match /users/{userId} {
      allow read, write: if true; // For testing - allow all access
    }
    
    // Faculty records collection - allow read/write for authenticated users
    match /facultyRecords/{recordId} {
      allow read, write: if true; // For testing - allow all access
    }
  }
}
